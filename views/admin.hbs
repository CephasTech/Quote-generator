<div class="admin-container">

<h1>⚙️ Quote Admin Dashboard</h1>


<div class="form-card">

<h2 id="formTitle">Add New Quote</h2>

<form id="quoteForm">

<input 
type="hidden"
id="quoteId"
>


<input 
type="text"
id="quote"
placeholder="Enter quote"
required
>


<input 
type="text"
id="author"
placeholder="Author"
required
>


<input 
type="text"
id="category"
placeholder="Category"
>


<button id="submitBtn">
Add Quote
</button>


<button 
type="button"
id="cancelBtn"
style="display:none;"
>
Cancel Edit
</button>


</form>

</div>


